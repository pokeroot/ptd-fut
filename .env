# Variables de Entorno para Pizarra Táctica Digital

# Django Backend
# !!! REEMPLAZA ESTO con tu propia clave secreta larga y aleatoria !!!
# Puedes generar una aquí: https://djecrety.ir/ o inventar una.
SECRET_KEY='deee71cc3acac64c24492c9f3a7e062923ba1fd6a0e4415a57a1b4d24f58254e'

# DEBUG=1 para desarrollo, DEBUG=0 para producción
DEBUG=1

# ALLOWED_HOSTS para desarrollo con Docker
# 'backend' permite que el contenedor frontend (Nginx) acceda al backend por su nombre de servicio.
ALLOWED_HOSTS='localhost,127.0.0.1,backend'

# Configuración de la Base de Datos PostgreSQL
# Estos nombres son usados por el servicio 'db' en docker-compose.yml y por Django para conectarse.
POSTGRES_DB=pizarra_tactica_db
POSTGRES_USER=pizarra_user
# !!! REEMPLAZA ESTO con la contraseña que quieras para tu base de datos de desarrollo !!!
POSTGRES_PASSWORD='6beadbf0b1a0a35e0633e37dad108232'
DB_HOST=db          # Nombre del servicio de la base de datos en docker-compose.yml
DB_PORT=5432        # Puerto estándar de PostgreSQL
